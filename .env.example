# Copy to .env for local overrides (never commit .env).
NODE_ENV=production
PORT=3000
# Local dev: omit HOST or set 127.0.0.1. Production/PaaS: 0.0.0.0 (default when NODE_ENV=production).
# HOST=0.0.0.0

# SEC: use a stable contact URL or email in User-Agent (required for polite use).
# SEC_USER_AGENT=xirr-stocks/1.0 (https://your-service.up.railway.app)

# Optional; defaults match prior hardcoded values.
# YAHOO_USER_AGENT=Mozilla/5.0 xirr-stocks/1.0

# INR backtests before ~Dec 2003: ship data/exinus-monthly.csv in the image or mount a volume.
# EXINUS_CSV_PATH=/path/to/exinus-monthly.csv

# Request limits (deployed defaults are safe for a public calculator).
# MAX_JSON_BODY_BYTES=262144
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=150
# RATE_LIMIT_MAX=0 disables rate limiting (local debugging only)

# LOG_LEVEL=info
# LOG_FILE=
